<Window x:Class="VersionedGameSaver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Versioned Game Saver"
        Height="720"
        Width="1180"
        MinHeight="620"
        MinWidth="980"
        Background="#F5F7FA">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinHeight" Value="32" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2937" />
        </Style>
        <Style x:Key="PaneTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#0F172A" Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Versioned Game Saver"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="LibraryText"
                               Text="No library selected"
                               Foreground="#CBD5E1"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Choose Library" Click="ChooseLibrary_Click" />
                    <Button Content="Scan Games" Click="ScanGames_Click" />
                    <Button Content="Add Manual Profile" Margin="0" Click="AddManualProfile_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="230" />
                <ColumnDefinition Width="2.2*" MinWidth="260" />
                <ColumnDefinition Width="3*" MinWidth="340" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" Padding="14" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource PaneTitle}" Text="Games" />
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                        <Button Content="Delete Game Backup" Margin="0" Click="DeleteGame_Click" />
                    </StackPanel>
                    <ListBox x:Name="GamesList" SelectionChanged="GamesList_SelectionChanged" />
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" Padding="14" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource PaneTitle}" Text="Saves, Worlds, Files" />
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                        <Button Content="Back Up Selected" Margin="0,0,0,8" Click="BackupSelected_Click" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Add Folder" Margin="0" Click="AddFolderScope_Click" />
                            <Button Grid.Column="2" Content="Add File" Margin="0" Click="AddFileScope_Click" />
                        </Grid>
                        <Button Content="Delete Scope" Margin="0" Click="DeleteScope_Click" />
                    </StackPanel>
                    <ListBox x:Name="ScopesList" SelectionChanged="ScopesList_SelectionChanged" />
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" Padding="14">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource PaneTitle}" Text="Versions" />
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                        <TextBlock x:Name="VersionDetailsText" Text="Select a version to see details." TextWrapping="Wrap" Margin="0,0,0,8" />
                        <TextBlock Text="Notes" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBox x:Name="NotesText"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="74"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,10" />
                        <WrapPanel>
                            <Button Content="Restore" Click="RestoreSelected_Click" />
                            <Button Content="Overwrite" Click="OverwriteSelected_Click" />
                            <Button Content="Edit Name/Notes" Click="EditSnapshot_Click" />
                            <Button Content="Delete Version" Margin="0" Click="DeleteSnapshot_Click" />
                        </WrapPanel>
                    </StackPanel>

                    <TabControl x:Name="VersionsTabs" SelectionChanged="VersionsTabs_SelectionChanged">
                        <TabItem Header="Versions">
                            <ListBox x:Name="ManualSnapshotsList" SelectionChanged="SnapshotsList_SelectionChanged" />
                        </TabItem>
                        <TabItem Header="Safety">
                            <ListBox x:Name="SafetySnapshotsList" SelectionChanged="SnapshotsList_SelectionChanged" />
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
