<Window x:Class="VersionedGameSaver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Versioned Game Saver"
        Height="720"
        Width="1180"
        MinHeight="620"
        MinWidth="980"
        Background="#F5F7FA">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinHeight" Value="32" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2937" />
        </Style>
        <Style x:Key="PaneTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#0F172A" Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Versioned Game Saver"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="LibraryText"
                               Text="No library selected"
                               Foreground="#CBD5E1"
                               Margin="0,4,0,0" />
                    <TextBlock x:Name="StatusText"
                               Text="Ready"
                               Foreground="#93C5FD"
                               Margin="0,4,0,0" />
                    <TextBox x:Name="OutputLogText"
                             Text="Ready"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Background="#111827"
                             Foreground="#CBD5E1"
                             BorderBrush="#334155"
                             BorderThickness="1"
                             FontFamily="Consolas"
                             FontSize="11"
                             Height="72"
                             Margin="0,8,0,0"
                             Padding="6" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ChooseLibraryButton" Content="Choose Library" Click="ChooseLibrary_Click" />
                    <Button x:Name="ScanGamesButton" Content="Scan Games" Click="ScanGames_Click" />
                    <Button x:Name="CancelScanButton" Content="Cancel Scan" Visibility="Collapsed" Margin="0" Click="CancelScan_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="230" />
                <ColumnDefinition Width="2.2*" MinWidth="260" />
                <ColumnDefinition Width="3*" MinWidth="340" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" Padding="14" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource PaneTitle}" Text="Games" />
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                        <Button x:Name="BackupAllGamesButton" Content="Back Up All Games" Margin="0,0,0,8" Click="BackupAllGames_Click" />
                        <Button x:Name="AddCustomGameButton" Content="Add Custom Game" Margin="0,0,0,8" Click="AddCustomGame_Click" />
                        <Button x:Name="RemoveGameButton" Content="Remove game from backup library" Margin="0" Click="DeleteGame_Click" />
                    </StackPanel>
                    <ListBox x:Name="GamesList" SelectionMode="Extended" SelectionChanged="GamesList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2,4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />

                                    <Border Grid.Column="1"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="5,1"
                                            Margin="8,0,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F1F5F9" />
                                                <Setter Property="BorderBrush" Value="#CBD5E1" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDetected}" Value="True">
                                                        <Setter Property="Background" Value="#E0F2FE" />
                                                        <Setter Property="BorderBrush" Value="#7DD3FC" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding SourceText}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#475569" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDetected}" Value="True">
                                                            <Setter Property="Foreground" Value="#075985" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <Border Grid.Column="2"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="5,1"
                                            Margin="6,0,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F8FAFC" />
                                                <Setter Property="BorderBrush" Value="#CBD5E1" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasBackups}" Value="True">
                                                        <Setter Property="Background" Value="#DCFCE7" />
                                                        <Setter Property="BorderBrush" Value="#86EFAC" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding BackupText}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#64748B" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasBackups}" Value="True">
                                                            <Setter Property="Foreground" Value="#166534" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="3"
                                               Text="{Binding VersionCountText}"
                                               Foreground="#64748B"
                                               FontSize="11"
                                               Margin="0,2,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" Padding="14" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource PaneTitle}" Text="Live Save Data" />
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                        <Button x:Name="BackupSelectedButton" Content="Back Up Selected" Margin="0,0,0,8" Click="BackupSelected_Click" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="AddFolderButton" Grid.Column="0" Content="Add Folder" Margin="0" Click="AddFolderScope_Click" />
                            <Button x:Name="AddFileButton" Grid.Column="2" Content="Add File" Margin="0" Click="AddFileScope_Click" />
                        </Grid>
                    </StackPanel>
                    <ListBox x:Name="LiveSavesList" SelectionChanged="LiveSavesList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2,4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding KindText}" />
                                    <Border Grid.Column="1"
                                            Background="#E0F2FE"
                                            BorderBrush="#7DD3FC"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="5,1"
                                            Margin="8,0,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LatestText}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding LatestText}"
                                                   Foreground="#075985"
                                                   FontSize="10"
                                                   FontWeight="SemiBold" />
                                    </Border>

                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="2"
                                               Text="{Binding ModifiedText}"
                                               Foreground="#64748B"
                                               FontSize="11"
                                               Margin="0,2,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <EventSetter Event="PreviewMouseRightButtonDown" Handler="LiveSavesListItem_PreviewMouseRightButtonDown" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Go to Folder" Click="GoToLiveSaveFolder_Click" />
                                <MenuItem Header="Details" Click="ShowScopeDetails_Click" />
                                <Separator />
                                <MenuItem Header="Edit Alias" Click="EditScopeAlias_Click" />
                                <MenuItem Header="Clear Alias" Click="ClearScopeAlias_Click" />
                                <Separator />
                                <MenuItem Header="Delete Save Entry" Click="DeleteScope_Click" />
                            </ContextMenu>
                        </ListBox.ContextMenu>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" MinHeight="180" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="220" MinHeight="90" MaxHeight="220" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource PaneTitle}" Text="Versions" />

                    <TabControl x:Name="VersionsTabs" Grid.Row="1" MinHeight="180" SelectionChanged="VersionsTabs_SelectionChanged">
                        <TabItem Header="Versions">
                            <ListView x:Name="ManualVersionsList" SelectionMode="Extended" SelectionChanged="VersionsList_SelectionChanged" GridViewColumnHeader.Click="ManualSnapshotHeader_Click">
                                <ListView.View>
                                    <GridView AllowsColumnReorder="True">
                                        <GridViewColumn Header="Slot" Width="48" DisplayMemberBinding="{Binding SlotText}" />
                                        <GridViewColumn Header="Save Entry" Width="130" DisplayMemberBinding="{Binding SaveEntryName}" />
                                        <GridViewColumn Header="Date" Width="130" DisplayMemberBinding="{Binding CreatedText}" />
                                        <GridViewColumn Header="Alias" Width="130">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding AliasText}"
                                                               Padding="4,2"
                                                               TextTrimming="CharacterEllipsis" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Files" Width="64" DisplayMemberBinding="{Binding FileCountText}" />
                                        <GridViewColumn Header="Size" Width="78" DisplayMemberBinding="{Binding SizeText}" />
                                    </GridView>
                                </ListView.View>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <EventSetter Event="PreviewMouseRightButtonDown" Handler="SnapshotListItem_PreviewMouseRightButtonDown" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Go to Folder" Click="GoToVersionFolder_Click" />
                                        <MenuItem Header="Details" Click="ShowSnapshotDetails_Click" />
                                        <MenuItem Header="Import Prior Save..." Click="ImportPriorSave_Click" />
                                        <MenuItem Header="Change Slot Number..." Click="ChangeSlot_Click" />
                                        <MenuItem Header="Edit Alias" Click="EditSnapshotAlias_Click" />
                                        <MenuItem Header="Clear Alias" Click="ClearSnapshotAlias_Click" />
                                        <Separator />
                                        <MenuItem Header="Restore" Click="RestoreSelected_Click" />
                                        <MenuItem Header="Overwrite" Click="OverwriteSelected_Click" />
                                        <Separator />
                                        <MenuItem Header="Delete Version" Click="DeleteSnapshot_Click" />
                                    </ContextMenu>
                                </ListView.ContextMenu>
                            </ListView>
                        </TabItem>
                        <TabItem Header="Safety">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top"
                                           Text="Safety snapshots are automatic backups of the current live save data created before restoring another version."
                                           TextWrapping="Wrap"
                                           Foreground="#64748B"
                                           FontSize="11"
                                           Margin="0,0,0,8" />
                            <ListView x:Name="SafetyVersionsList" SelectionMode="Extended" SelectionChanged="VersionsList_SelectionChanged" GridViewColumnHeader.Click="SafetySnapshotHeader_Click">
                                <ListView.View>
                                    <GridView AllowsColumnReorder="True">
                                        <GridViewColumn Header="Slot" Width="48" DisplayMemberBinding="{Binding SlotText}" />
                                        <GridViewColumn Header="Save Entry" Width="130" DisplayMemberBinding="{Binding SaveEntryName}" />
                                        <GridViewColumn Header="Date" Width="130" DisplayMemberBinding="{Binding CreatedText}" />
                                        <GridViewColumn Header="Alias" Width="130">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding AliasText}"
                                                               Padding="4,2"
                                                               TextTrimming="CharacterEllipsis" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Files" Width="64" DisplayMemberBinding="{Binding FileCountText}" />
                                        <GridViewColumn Header="Size" Width="78" DisplayMemberBinding="{Binding SizeText}" />
                                    </GridView>
                                </ListView.View>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <EventSetter Event="PreviewMouseRightButtonDown" Handler="SnapshotListItem_PreviewMouseRightButtonDown" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ContextMenu>
                                    <ContextMenu>
                                            <MenuItem Header="Go to Folder" Click="GoToVersionFolder_Click" />
                                            <MenuItem Header="Details" Click="ShowSnapshotDetails_Click" />
                                            <MenuItem Header="Change Slot Number..." Click="ChangeSlot_Click" />
                                            <MenuItem Header="Edit Alias" Click="EditSnapshotAlias_Click" />
                                        <MenuItem Header="Clear Alias" Click="ClearSnapshotAlias_Click" />
                                        <Separator />
                                        <MenuItem Header="Restore" Click="RestoreSelected_Click" />
                                        <MenuItem Header="Overwrite" Click="OverwriteSelected_Click" />
                                        <Separator />
                                        <MenuItem Header="Delete Version" Click="DeleteSnapshot_Click" />
                                    </ContextMenu>
                                </ListView.ContextMenu>
                            </ListView>
                            </DockPanel>
                        </TabItem>
                    </TabControl>

                    <GridSplitter Grid.Row="2"
                                  Height="6"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Background="#E2E8F0"
                                  ResizeDirection="Rows"
                                  ResizeBehavior="PreviousAndNext" />

                    <ScrollViewer Grid.Row="3"
                                  MaxHeight="220"
                                  Margin="0,10,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock x:Name="VersionDetailsText" Text="Select a version to see details." TextWrapping="Wrap" Margin="0,0,0,8" />
                            <TextBlock Text="Alias" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBox x:Name="AliasText"
                                     TextChanged="AliasText_TextChanged"
                                     LostFocus="AliasText_LostFocus"
                                     Margin="0,0,0,8" />
                            <TextBlock Text="Notes" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBox x:Name="NotesText"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Height="58"
                                     VerticalScrollBarVisibility="Auto"
                                     TextChanged="NotesText_TextChanged"
                                     Margin="0,0,0,10" />
                            <WrapPanel>
                                <Button x:Name="AddEmptySlotButton" Content="Add Empty Slot..." Click="AddEmptySlot_Click" />
                                <Button x:Name="ImportPriorSaveButton" Content="Import Prior Save..." Click="ImportPriorSave_Click" />
                                <Button x:Name="ChangeSlotButton" Content="Change Slot Number..." Click="ChangeSlot_Click" />
                                <Button x:Name="RestoreButton" Content="Restore" Click="RestoreSelected_Click" />
                                <Button x:Name="OverwriteButton" Content="Overwrite" Click="OverwriteSelected_Click" />
                                <Button x:Name="DeleteVersionButton" Content="Delete Version" Margin="0" Click="DeleteSnapshot_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>

