<Window x:Class="VersionedGameSaver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Versioned Game Saver"
        Height="720"
        Width="1180"
        MinHeight="620"
        MinWidth="980"
        Background="#F5F7FA">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinHeight" Value="32" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2937" />
        </Style>
        <Style x:Key="PaneTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#0F172A" Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Versioned Game Saver"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="LibraryText"
                               Text="No library selected"
                               Foreground="#CBD5E1"
                               Margin="0,4,0,0" />
                    <TextBlock x:Name="StatusText"
                               Text="Ready"
                               Foreground="#93C5FD"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ChooseLibraryButton" Content="Choose Library" Click="ChooseLibrary_Click" />
                    <Button x:Name="ScanGamesButton" Content="Scan Games" Click="ScanGames_Click" />
                    <Button x:Name="AddManualProfileButton" Content="Add Manual Profile" Margin="0" Click="AddManualProfile_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="230" />
                <ColumnDefinition Width="2.2*" MinWidth="260" />
                <ColumnDefinition Width="3*" MinWidth="340" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" Padding="14" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource PaneTitle}" Text="Games" />
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                        <Button x:Name="RemoveGameButton" Content="Remove Game From Library" Margin="0" Click="DeleteGame_Click" />
                    </StackPanel>
                    <ListBox x:Name="GamesList" SelectionChanged="GamesList_SelectionChanged" />
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" Padding="14" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource PaneTitle}" Text="Saves / Files" />
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                        <Button x:Name="BackupSelectedButton" Content="Back Up Selected" Margin="0,0,0,8" Click="BackupSelected_Click" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="AddFolderButton" Grid.Column="0" Content="Add Folder" Margin="0" Click="AddFolderScope_Click" />
                            <Button x:Name="AddFileButton" Grid.Column="2" Content="Add File" Margin="0" Click="AddFileScope_Click" />
                        </Grid>
                    </StackPanel>
                    <ListBox x:Name="ScopesList" SelectionChanged="ScopesList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <EventSetter Event="PreviewMouseRightButtonDown" Handler="ScopesListItem_PreviewMouseRightButtonDown" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Details" Click="ShowScopeDetails_Click" />
                                <Separator />
                                <MenuItem Header="Edit Alias" Click="EditScopeAlias_Click" />
                                <MenuItem Header="Clear Alias" Click="ClearScopeAlias_Click" />
                                <Separator />
                                <MenuItem Header="Delete Save Entry" Click="DeleteScope_Click" />
                            </ContextMenu>
                        </ListBox.ContextMenu>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" Padding="14">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource PaneTitle}" Text="Versions" />
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                        <TextBlock x:Name="VersionDetailsText" Text="Select a version to see details." TextWrapping="Wrap" Margin="0,0,0,8" />
                        <TextBlock Text="Notes" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBox x:Name="NotesText"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="74"
                                 VerticalScrollBarVisibility="Auto"
                                 TextChanged="NotesText_TextChanged"
                                 Margin="0,0,0,10" />
                        <WrapPanel>
                            <Button x:Name="RestoreButton" Content="Restore" Click="RestoreSelected_Click" />
                            <Button x:Name="OverwriteButton" Content="Overwrite" Click="OverwriteSelected_Click" />
                            <Button x:Name="DeleteVersionButton" Content="Delete Version" Margin="0" Click="DeleteSnapshot_Click" />
                        </WrapPanel>
                    </StackPanel>

                    <TabControl x:Name="VersionsTabs" SelectionChanged="VersionsTabs_SelectionChanged">
                        <TabItem Header="Versions">
                            <ListView x:Name="ManualSnapshotsList" SelectionMode="Extended" SelectionChanged="SnapshotsList_SelectionChanged" GridViewColumnHeader.Click="ManualSnapshotHeader_Click">
                                <ListView.View>
                                    <GridView AllowsColumnReorder="True">
                                        <GridViewColumn Header="Slot" Width="48" DisplayMemberBinding="{Binding SlotText}" />
                                        <GridViewColumn Header="Alias" Width="130">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding EditableAlias, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             MinWidth="104"
                                                             Padding="4,2"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             GotFocus="AliasTextBox_GotFocus"
                                                             KeyDown="AliasTextBox_KeyDown"
                                                             LostFocus="AliasTextBox_LostFocus" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Save Entry" Width="130" DisplayMemberBinding="{Binding SaveEntryName}" />
                                        <GridViewColumn Header="Date" Width="130" DisplayMemberBinding="{Binding CreatedText}" />
                                        <GridViewColumn Header="Files" Width="64" DisplayMemberBinding="{Binding FileCountText}" />
                                        <GridViewColumn Header="Size" Width="78" DisplayMemberBinding="{Binding SizeText}" />
                                    </GridView>
                                </ListView.View>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <EventSetter Event="PreviewMouseRightButtonDown" Handler="SnapshotListItem_PreviewMouseRightButtonDown" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Details" Click="ShowSnapshotDetails_Click" />
                                        <MenuItem Header="Edit Alias" Click="EditSnapshotAlias_Click" />
                                        <MenuItem Header="Clear Alias" Click="ClearSnapshotAlias_Click" />
                                        <Separator />
                                        <MenuItem Header="Restore" Click="RestoreSelected_Click" />
                                        <MenuItem Header="Overwrite" Click="OverwriteSelected_Click" />
                                        <Separator />
                                        <MenuItem Header="Delete Version" Click="DeleteSnapshot_Click" />
                                    </ContextMenu>
                                </ListView.ContextMenu>
                            </ListView>
                        </TabItem>
                        <TabItem Header="Safety">
                            <ListView x:Name="SafetySnapshotsList" SelectionMode="Extended" SelectionChanged="SnapshotsList_SelectionChanged" GridViewColumnHeader.Click="SafetySnapshotHeader_Click">
                                <ListView.View>
                                    <GridView AllowsColumnReorder="True">
                                        <GridViewColumn Header="Slot" Width="48" DisplayMemberBinding="{Binding SlotText}" />
                                        <GridViewColumn Header="Alias" Width="130">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding EditableAlias, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             MinWidth="104"
                                                             Padding="4,2"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             GotFocus="AliasTextBox_GotFocus"
                                                             KeyDown="AliasTextBox_KeyDown"
                                                             LostFocus="AliasTextBox_LostFocus" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Save Entry" Width="130" DisplayMemberBinding="{Binding SaveEntryName}" />
                                        <GridViewColumn Header="Date" Width="130" DisplayMemberBinding="{Binding CreatedText}" />
                                        <GridViewColumn Header="Files" Width="64" DisplayMemberBinding="{Binding FileCountText}" />
                                        <GridViewColumn Header="Size" Width="78" DisplayMemberBinding="{Binding SizeText}" />
                                    </GridView>
                                </ListView.View>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <EventSetter Event="PreviewMouseRightButtonDown" Handler="SnapshotListItem_PreviewMouseRightButtonDown" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Details" Click="ShowSnapshotDetails_Click" />
                                        <MenuItem Header="Edit Alias" Click="EditSnapshotAlias_Click" />
                                        <MenuItem Header="Clear Alias" Click="ClearSnapshotAlias_Click" />
                                        <Separator />
                                        <MenuItem Header="Restore" Click="RestoreSelected_Click" />
                                        <MenuItem Header="Overwrite" Click="OverwriteSelected_Click" />
                                        <Separator />
                                        <MenuItem Header="Delete Version" Click="DeleteSnapshot_Click" />
                                    </ContextMenu>
                                </ListView.ContextMenu>
                            </ListView>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
